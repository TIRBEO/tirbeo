generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model User {
  id               String      @id @default(cuid())
  email            String      @unique
  passwordHash     String     @default("") @map("password_hash")
  name             String?
  photoUrl         String?    @map("photo_url")
  secondaryEmail   String?    @map("secondary_email")
  phoneNumber      String?    @map("phone_number")
  occupation       String?
  googleId        String?      @unique @map("google_id")
  githubId        String?      @unique @map("github_id")
  adminRole        String?     @map("admin_role")
  totpSecret       String?    @map("totp_secret")
  is2FAEnabled     Boolean     @default(false) @map("is_2fa_enabled")
  isBanned         Boolean     @default(false) @map("is_banned")
  isSuspended      Boolean     @default(false) @map("is_suspended")
  lastActiveAt     DateTime?  @map("last_active_at")
  preferences      Json        @default("{}")
  bio              String?
  website          String?
  linkedin         String?
  github           String?    @map("github_username")
  twitter          String?
  country          String?
  timezone         String?
  language         String?    @default("en")
  theme            String?    @default("system")
  dateFormat       String?    @default("MM/DD/YYYY") @map("date_format")
  timeFormat       String?    @default("12h") @map("time_format")
  fontSize         String?    @default("default") @map("font_size")
  reduceMotion     Boolean    @default(false) @map("reduce_motion")
  highContrast     Boolean    @default(false) @map("high_contrast")
  emailVerified    Boolean    @default(false) @map("email_verified")
  phoneVerified    Boolean    @default(false) @map("phone_verified")
  companyName      String?    @map("company_name")
  companyRole      String?    @map("company_role")
  industry         String?
  companySize      String?    @map("company_size")
  gender           String?
  birthday         DateTime?
  karmaPoints      Int        @default(0) @map("karma_points")
  isVerified       Boolean    @default(false) @map("is_verified")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  sessions             Session[]
  memberships          Membership[]
  ownedWorkspaces      Workspace[] @relation("WorkspaceOwner")
  otps                 Otp[]
  roleAssignments      UserRole[]
  notifications        Notification[]
  notificationPref     NotificationPreference?
  contentReports       ContentReport[]     @relation("ContentReporter")
  contentReviews       ContentReport[]     @relation("ContentReviewer")
  mediaUploads         Media[]
  auditEvents          AuditEvent[]
  recoveryCodes        RecoveryCode[]
  integrations         Integration[]
  securityEvents       SecurityEvent[]

  @@map("users")
  @@index([email])
  @@index([adminRole])
  @@index([lastActiveAt])
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String   @map("owner_id")
  owner     User     @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships Membership[]

  @@map("workspaces")
  @@index([slug])
}

model Membership {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  workspaceId String   @map("workspace_id")
  role        WorkspaceRole     @default(MEMBER)
  createdAt   DateTime @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("memberships")
  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model Session {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  token     String?
  status    String?   @default("active")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address")
  location  String?
  deviceName String?  @map("device_name")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@index([userId])
  @@index([token])
}

model Route {
  id           String   @id @default(cuid())
  path         String
  method       String   @default("GET")
  target       String?
  description  String?
  allowedRoles String[] @default(["member"]) @map("allowed_roles")
  internal     Boolean  @default(false)
  enabled      Boolean  @default(true)
  rateLimit    Int?     @map("rate_limit")
  cacheTtl     Int?     @map("cache_ttl")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("routes")
  @@unique([path, method])
}

model Log {
  id        String    @id @default(cuid())
  ip        String?
  method    String
  path      String
  userId    String?   @map("user_id")
  status    Int?
  duration  Int?
  size      Int?
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("logs")
  @@index([createdAt])
  @@index([ip])
  @@index([userId])
}

model Blocklist {
  id         String    @id @default(cuid())
  type       String
  value      String
  reason     String?
  addedById  String?   @map("added_by_id")
  expiresAt  DateTime? @map("expires_at")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("blocklist")
  @@unique([type, value])
  @@index([value])
}

model SiteConfig {
  id        String   @id @default(cuid())
  app       String   @unique
  config    Json
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("site_configs")
  @@index([app])
}

model AppRole {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String   @default("#4f7aff")
  icon        String   @default("shield")
  isSystem    Boolean  @default(false) @map("is_system")
  permissions Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  assignments UserRole[]

  @@map("app_roles")
  @@index([name])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   AppRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@map("user_roles")
  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model Otp {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  otpHash   String   @map("otp_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otps")
  @@index([userId])
  @@index([type])
}

model SignupOtp {
  id        String   @id @default(cuid())
  email     String
  otpHash   String   @map("otp_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("signup_otps")
  @@index([email])
}

// ─── Email System ──────────────────────────────────────

model EmailConfig {
  id        String   @id @default(cuid())
  provider  String   @default("resend")
  apiKey    String?  @map("api_key")
  smtpHost  String?  @map("smtp_host")
  smtpPort  Int?     @map("smtp_port")
  smtpUser  String?  @map("smtp_user")
  smtpPass  String?  @map("smtp_pass")
  fromEmail String   @default("noreply@tirbeo.app") @map("from_email")
  fromName  String   @default("Tirbeo") @map("from_name")
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("email_configs")
}

model EmailTemplate {
  id           String   @id @default(cuid())
  name         String   @unique
  label        String
  subject      String
  htmlBody     String   @map("html_body")
  variables    Json     @default("[]")
  fromEmail    String?  @map("from_email")
  fromName     String?  @map("from_name")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("email_templates")
  @@index([name])
}

// ─── Notifications ─────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  title     String
  body      String?
  link      String?
  icon      String?
  priority  Int?
  read      Boolean  @default(false)
  readAt    DateTime? @map("read_at")
  emailSent Boolean  @default(false) @map("email_sent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
  @@index([userId, read])
  @@index([createdAt])
}

model NotificationPreference {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  emailDigest  String   @default("daily") @map("email_digest")
  digestTime   String   @default("08:00") @map("digest_time")
  mention      Boolean  @default(true)
  comment      Boolean  @default(true)
  report       Boolean  @default(true)
  system       Boolean  @default(true)
  marketing    Boolean  @default(false)
  security     Boolean  @default(true)
  product      Boolean  @default(true)
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ─── Content Moderation ─────────────────────────────────

model ContentReport {
  id            String   @id @default(cuid())
  reporterId    String   @map("reporter_id")
  targetType    String   @map("target_type")
  targetId      String   @map("target_id")
  reason        String
  description   String?
  status        String   @default("pending")
  priority      String?
  reviewedById  String?  @map("reviewed_by_id")
  reviewedAt    DateTime? @map("reviewed_at")
  action        String?
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  reporter   User @relation("ContentReporter", fields: [reporterId], references: [id])
  reviewedBy User? @relation("ContentReviewer", fields: [reviewedById], references: [id])

  @@map("content_reports")
  @@index([status])
  @@index([targetType, targetId])
  @@index([createdAt])
}

// ─── Media Library ──────────────────────────────────────

model Media {
  id           String   @id @default(cuid())
  fileName     String   @map("file_name")
  originalName String?  @map("original_name")
  fileSize     Int      @map("file_size")
  mimeType     String   @map("mime_type")
  url          String
  storagePath  String?  @map("storage_path")
  thumbnail    String?
  altText      String?  @map("alt_text")
  caption      String?
  width        Int?
  height       Int?
  duration     Int?
  uploadedById String   @map("uploaded_by")
  folder       String   @default("general")
  tags         Json     @default("[]")
  isPublic     Boolean  @default(true) @map("is_public")
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@map("media")
  @@index([folder])
  @@index([mimeType])
  @@index([uploadedById])
}

// ─── Audit Trail ────────────────────────────────────────

model AuditEvent {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  metadata   Json     @default("{}")
  severity   String   @default("info")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@map("audit_events")
  @@index([action])
  @@index([actorId])
  @@index([targetType, targetId])
  @@index([severity])
  @@index([createdAt])
}

// ─── Security Events ────────────────────────────────────

model SecurityEvent {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  type       String
  description String?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  location   String?
  metadata   Json     @default("{}")
  severity   String   @default("info")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("security_events")
  @@index([userId])
  @@index([createdAt])
}

// ─── 2FA / Recovery Codes ───────────────────────────────

model RecoveryCode {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  code      String
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  usedAt    DateTime? @map("used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("recovery_codes")
  @@index([userId])
  @@index([code])
}

// ─── Newsletter Subscribers ────────────────────────────

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String   @default("landing")
  status    String   @default("active")
  tags      Json     @default("[]")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("subscribers")
  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model Integration {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  provider     String
  connected    Boolean  @default(false)
  accessToken  String?  @map("access_token")
  refreshToken String?  @map("refresh_token")
  expiresAt    DateTime? @map("expires_at")
  scope        String?
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("integrations")
  @@unique([userId, provider])
  @@index([userId])
}

// ─── Theme Configuration ───────────────────────────────

model ThemeConfig {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(false) @map("is_active")
  isDefault Boolean  @default(false) @map("is_default")

  bgPrimary     String @default("#08150F") @map("bg_primary")
  bgSecondary   String @default("#101c13") @map("bg_secondary")
  bgCard        String @default("#12271D") @map("bg_card")
  bgElevated    String @default("#1a3326") @map("bg_elevated")

  textPrimary   String @default("#F2EEE8") @map("text_primary")
  textSecondary String @default("#B7C6BE") @map("text_secondary")
  textMuted     String @default("#6b8a7a") @map("text_muted")

  accentPrimary   String @default("#569578") @map("accent_primary")
  accentSecondary String @default("#275d46") @map("accent_secondary")
  accentHover     String @default("#6aab8d") @map("accent_hover")

  success   String @default("#59C173")
  warning   String @default("#F4B942")
  error     String @default("#E45D5D")

  borderColor     String @default("rgba(255,255,255,0.08)") @map("border_color")
  borderHover     String @default("rgba(255,255,255,0.14)") @map("border_hover")

  fontPrimary  String @default("Inter") @map("font_primary")
  fontHeading  String @default("Plus Jakarta Sans") @map("font_heading")
  borderRadius String @default("16px") @map("border_radius")

  logoUrl      String? @map("logo_url")
  brandName    String @default("Tirbeo") @map("brand_name")
  brandTagline String @default("Premium Social Platform") @map("brand_tagline")

  lightBgPrimary     String? @map("light_bg_primary")
  lightBgSecondary   String? @map("light_bg_secondary")
  lightTextPrimary   String? @map("light_text_primary")
  lightAccentPrimary String? @map("light_accent_primary")

  emailHeaderBg      String @default("linear-gradient(135deg,#022B22,#275D46,#569578)") @map("email_header_bg")
  emailButtonColor   String @default("#569578") @map("email_button_color")
  emailTextColor     String @default("#B7C6BE") @map("email_text_color")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("theme_configs")
  @@index([isActive])
}
