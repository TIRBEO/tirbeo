{
  "name": "@tirbeo/database",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.mjs",
      "require": "./dist/types.js"
    },
    "./server-client": {
      "types": "./dist/server-client.d.ts",
      "import": "./dist/server-client.mjs",
      "require": "./dist/server-client.js"
    },
    "./middleware-client": {
      "types": "./dist/middleware-client.d.ts",
      "import": "./dist/middleware-client.mjs",
      "require": "./dist/middleware-client.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/migrations/run.ts",
    "db:seed": "tsx src/migrations/seed.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.0",
    "@supabase/ssr": "^0.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tirbeo/config": "workspace:*",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.10.0",
    "next": "^15.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
