{
  "name": "tirbeo",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "cd apps/landing && npm install && npm run build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:migrate": "pnpm --filter @tirbeo/database db:migrate",
    "db:seed": "pnpm --filter @tirbeo/database db:seed"
  },
  "dependencies": {
    "next": "^15.1.0"
  },
  "devDependencies": {

    "turbo": "^2.3.0",
    "prettier": "^3.4.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.0"
}
